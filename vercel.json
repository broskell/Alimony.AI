{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/uploads/(.*)", "destination": "/api/uploads/$1" },
    { "source": "/assets/(.*)", "destination": "/client/dist/assets/$1" },
    { "source": "/((?!api|uploads|assets).*\\..*)", "destination": "/client/dist/$1" },
    { "source": "/(.*)", "destination": "/client/dist/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "server/node_modules/.prisma/client/**",
        "server/node_modules/@prisma/client/**"
      ]
    }
  }
}
